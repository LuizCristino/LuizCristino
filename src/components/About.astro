---
import type { Translations } from '../i18n/utils';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="about" class="py-28 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-foreground mb-2">{t.about.title}</h2>
    <div class="h-1 w-16 bg-primary rounded-full mb-12"></div>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Text -->
      <div class="md:col-span-3 space-y-6 text-muted-foreground leading-relaxed">
        <p>{t.about.intro}</p>

        <ul class="space-y-2 pl-4">
          {t.about.pet_projects.map((p) => (
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1">▸</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <div>
          <p class="text-sm font-semibold text-foreground uppercase tracking-wider mb-3">
            {t.about.degrees_label}
          </p>
          <div class="flex flex-col gap-2">
            {t.about.degrees.map((d) => (
              <div class="flex items-center gap-2 px-4 py-2 rounded-md border border-border bg-card text-sm">
                <span class="text-secondary">🎓</span>
                <span>{d}</span>
              </div>
            ))}
          </div>
        </div>

        <p>{t.about.current}</p>
        <p class="text-foreground/80">{t.about.next}</p>
      </div>

      <!-- Avatar -->
      <div class="md:col-span-2 flex justify-center md:justify-end">
        <div class="relative">
          <div class="w-56 h-56 rounded-2xl overflow-hidden border-2 border-primary/30 shadow-lg shadow-primary/10">
            <img
              src={`${base}/images/profiles/profile_000.png`}
              alt="Luiz Cristino"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-3 -right-3 w-56 h-56 rounded-2xl border border-primary/20 -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
