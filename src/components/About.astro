---
import type { Translations } from '../i18n/utils';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="about" class="py-28 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-foreground mb-2">{t.about.title}</h2>
    <div class="h-1 w-16 bg-primary rounded-full mb-12"></div>

    <!-- Bio + Avatar -->
    <div class="grid md:grid-cols-5 gap-12 items-start mb-20">
      <div class="md:col-span-3 space-y-6 text-muted-foreground leading-relaxed">
        <blockquote class="border-l-2 border-primary pl-4 italic text-foreground/80 text-lg">
          {t.about.motto}
        </blockquote>

        <p>{t.about.intro}</p>

        <ul class="space-y-2 pl-2">
          {t.about.pet_projects.map((p) => (
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 shrink-0">▸</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-foreground mb-3">
            {t.about.degrees_label}
          </p>
          <div class="flex flex-col gap-2">
            {t.about.degrees.map((d) => (
              <div class="flex items-center gap-2 px-4 py-2 rounded-md border border-border bg-card text-sm">
                <span class="text-secondary">🎓</span>
                <span>{d}</span>
              </div>
            ))}
          </div>
        </div>

        <p set:html={t.about.current} />
        <p class="text-foreground/80">{t.about.next}</p>
      </div>

      <!-- Avatar -->
      <div class="md:col-span-2 flex justify-center md:justify-end">
        <div class="relative">
          <div class="w-56 h-56 rounded-2xl overflow-hidden border-2 border-primary/30 shadow-lg shadow-primary/10">
            <img
              src={`${base}/images/profiles/profile_000.png`}
              alt="Luiz Cristino"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-3 -right-3 w-56 h-56 rounded-2xl border border-primary/20 -z-10"></div>
        </div>
      </div>
    </div>

    <!-- Community & Open Source -->
    <div class="mb-20">
      <h3 class="text-xl font-bold text-foreground mb-2">{t.about.community_title}</h3>
      <div class="h-0.5 w-10 bg-secondary rounded-full mb-6"></div>

      <p class="text-muted-foreground leading-relaxed mb-8 max-w-2xl">
        {t.about.community_intro}
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {t.about.community_items.map((item) => (
          <div class="flex items-start gap-3 p-4 rounded-lg border border-border bg-card hover:border-secondary/50 transition-colors">
            <span class="text-secondary mt-0.5">⬡</span>
            <div>
              <p class="text-sm font-semibold text-foreground">{item.name}</p>
              <p class="text-xs text-muted-foreground mt-0.5 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Kotlin & Laravel passions -->
    <div>
      <h3 class="text-xl font-bold text-foreground mb-2">{t.about.passions_title}</h3>
      <div class="h-0.5 w-10 bg-accent rounded-full mb-6"></div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Kotlin -->
        <div class="p-6 rounded-xl border border-border bg-card hover:border-primary/40 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-lg">K</div>
            <h4 class="font-bold text-foreground">{t.about.kotlin.title}</h4>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed">{t.about.kotlin.desc}</p>
        </div>

        <!-- Laravel -->
        <div class="p-6 rounded-xl border border-border bg-card hover:border-accent/40 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-lg">L</div>
            <h4 class="font-bold text-foreground">{t.about.laravel.title}</h4>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed">{t.about.laravel.desc}</p>
        </div>
      </div>
    </div>
  </div>
</section>
